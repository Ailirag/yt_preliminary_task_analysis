# Шаблон переменных окружения. Скопируйте в .env и впишите значения:
#   PowerShell:  Copy-Item .env.example .env
# .env грузится при старте (см. cli.py). ВАЖНО: реальные переменные окружения ОС
# имеют приоритет над .env — если переменная уже задана в системе, значение из .env игнорируется.
# .env в .gitignore и в репозиторий не попадёт. Значения в кавычки не заключать.

# --- Трекер / Wiki (обязательно) ---
YATRACKER_TOKEN_GT=
YATRACKER_ORGID_GT=

# --- z.ai GLM (обязательно для пилота: analyst=GLM-5.2, vision=GLM-4.6V) ---
ZAI_API_KEY=

# --- Yandex AI Studio (опционально, если сравниваете с YandexGPT) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- Опционально ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
